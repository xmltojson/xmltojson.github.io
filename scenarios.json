[
  {
    "name": "Scenario 1 Переклад UK to EN",
    "disabled": false,
    "steps": [
      {
        "type": "given",
        "text": "I open https://xmltojson.github.io/ShvydkoPereklad5.html",
        "disabled": false
      },
      {
        "type": "and",
        "text": "I click \"body > div.app > div.tabs > button:nth-child(1)\"",
        "disabled": false
      },
      {
        "type": "and",
        "text": "I choose \"uk\" from \"#srcLang\"",
        "disabled": false
      },
      {
        "type": "and",
        "text": "I choose \"en\" from \"#tgtLang\"",
        "disabled": false
      },
      {
        "type": "and",
        "text": "I type \"машина їде по дорозі\" into \"#srcText\"",
        "disabled": false
      },
      {
        "type": "and",
        "text": "I click \"#translateBtn\"",
        "disabled": false
      },
      {
        "type": "and",
        "text": "wait 1000",
        "disabled": false
      },
      {
        "type": "and",
        "text": "field \"#tgtText\" has value \"the car is driving on the road\"",
        "disabled": false
      }
    ]
  },
  {
    "name": "Scenario 2 Фото UK to EN",
