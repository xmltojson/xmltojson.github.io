      {
        "type": "and",
        "text": "I choose \"en\" from \"#photoTgtLang\"",
        "disabled": false
      },
      {
        "type": "and",
        "text": "I click \"#ocrBtn\"",
        "disabled": false
      },
      {
        "type": "and",
        "text": "wait 1000",
        "disabled": false
      },
      {
        "type": "and",
        "text": "I see \"=== РОЗПІЗНАНО (UK) ===\\n\\nмашина їде по дорозі\\n\\n\\n=== ПЕРЕКЛАД (EN) • Google Translate ===\\n\\nthe car is driving on the road\" in \"#ocrResult\"",
        "disabled": false
